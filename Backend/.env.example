PORT=5000

DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=maintenance_management
DB_PORT=3306

CLOUD_NAME=
CLOUD_API_KEY=
CLOUD_API_SECRET=

JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret

# SMTP settings are required to email generated society admin credentials.
# For Gmail, use an app password instead of your normal account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-app-password
MAIL_FROM="Maintenance Management <your-email@gmail.com>"
